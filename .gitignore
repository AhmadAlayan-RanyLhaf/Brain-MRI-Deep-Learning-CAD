# .gitignore
.venv/
segmentation_data/*
!segmentation_data/images/
!segmentation_data/labels/
segmentation_data/images/*
!segmentation_data/images/sub-188_img.nii.gz
segmentation_data/labels/*
!segmentation_data/labels/sub-188_lbl.nii.gz
__pycache__/
*.pyc

# Exclude large models and NIfTI volumes
*.pt
*.pth
*.nii.gz
!segmentation_data/images/sub-188_img.nii.gz
!segmentation_data/labels/sub-188_lbl.nii.gz

# Exclude temporary slices and images at the root level
*.png
*.pdf

# Preprocessed numpy volume cache
miriad_processed/

# Temporary run directories
temp_cv_fold0/
temp/

# Ignore all training runs and local checkpoints
runs/*
!runs/cv_fold0/
!runs/cv_fold1/
!runs/cv_fold2/
!runs/cv_fold3/
!runs/cv_fold4/
!runs/segmentation/
runs/cv_fold0/*
!runs/cv_fold0/best.pt
runs/cv_fold1/*
!runs/cv_fold1/best.pt
runs/cv_fold2/*
!runs/cv_fold2/best.pt
runs/cv_fold3/*
!runs/cv_fold3/best.pt
runs/cv_fold4/*
!runs/cv_fold4/best.pt
runs/segmentation/*
!runs/segmentation/best.pt
# Exclude compiled documents and report-generation scripts
*.docx
*.pptx
*.ppt
*.html
generate_*.py
compare_segmentation_visuals.py
check_*.py
get_*.py

# Exclude YOLO dataset and results directories
yolo_dataset/
yolo_results/

# Exclude local test and scratch checking scripts
Check.py
Check2.py
testDataSet.py
calc_surface_metrics.py
generate_justification_docx.py
calc_unet_auc.py
inspect_classification.py
inspect_fold0.py
inspect_run.py
inspect_test.py
print_perfect_cv.py
search_best_seed.py
search_ensemble_weights.py
test_aggregations.py
test_ensemble.py

# Exclude backup folder for instance segmentation models
instance_models_backup/

# Exclude local-only reports and helpers from GitHub repository
reports/
helpers/

# Whitelist results directory to ensure they are tracked
!results/**

# Exclude OASIS raw and processed datasets and local tarballs
oasis_raw/
oasis_processed/
oasis_cross-sectional_*.tar.gz
oasis_cross-sectional_*.zip

